    {
      "parameters": {
        "jsCode": "const BIRD_FEED_PER_BIRD_KG = 0.12;\nconst FISH_FEED_PERCENT_BIOMASS = 0.04;\nconst FEED_VARIANCE_THRESHOLD = 15;\n\nconst totalBirds = $json.totalBirds;\nconst totalFish = $json.totalFish;\nconst avgFishWeight = $('Edit Fields').item.json.avgFishWeight;\n\nconst actualBirdFeedUsed = $('Edit Fields').item.json.actualBirdFeedUsed ?? 0;\nconst actualFishFeedUsed = $('Edit Fields').item.json.actualFishFeedUsed ?? 0;\n\nconst expectedBirdFeedKg = totalBirds * BIRD_FEED_PER_BIRD_KG;\nconst totalFishBiomassKg = totalFish * avgFishWeight;\nconst expectedFishFeedKg = totalFishBiomassKg * FISH_FEED_PERCENT_BIOMASS;\n\nconst totalExpectedFeed = expectedBirdFeedKg + expectedFishFeedKg;\nconst totalActualFeed = actualBirdFeedUsed + actualFishFeedUsed;\n\nconst feedVariancePercent = totalExpectedFeed > 0\n  ? ((totalActualFeed - totalExpectedFeed) / totalExpectedFeed) * 100\n  : 0;\n\n// Read the alertStatus already decided by the mortality Code node\nlet alertStatus = $json.alertStatus;\n\nconst feedVarianceAlert = Math.abs(feedVariancePercent) >= FEED_VARIANCE_THRESHOLD;\n\nif (feedVarianceAlert && alertStatus !== \"Normal\") {\n  alertStatus = alertStatus + \" + Feed Variance\";\n} else if (feedVarianceAlert) {\n  alertStatus = \"Feed Variance Alert\";\n}\n\nreturn {\n  ...$json,\n  expectedBirdFeedKg: Math.round(expectedBirdFeedKg * 100) / 100,\n  expectedFishFeedKg: Math.round(expectedFishFeedKg * 100) / 100,\n  actualFeedUsedKg: Math.round(totalActualFeed * 100) / 100,\n  feedVariancePercent: Math.round(feedVariancePercent * 100) / 100,\n  alertStatus\n};"
      },
