    {
      "parameters": {
        "jsCode": "// Yesterday's closing stock becomes today's opening totals\nconst totalBirds = $json.fields?.ClosingBirdStock ?? 0;\nconst totalFish = $json.fields?.ClosingFishStock ?? 0;\n\n// Deaths still come from today's form submission\nconst birdDeaths = $('Edit Fields').item.json.birdDeaths;\nconst fishDeaths = $('Edit Fields').item.json.fishDeaths;\nconst eggsCollected = $('Edit Fields').item.json.eggsCollected;\nconst pondId = $('Edit Fields').item.json.pondId;\nconst avgFishWeight = $('Edit Fields').item.json.avgFishWeight;\nconst date = $('Edit Fields').item.json.date;\n\nconst birdMortalityRate = totalBirds > 0 ? (birdDeaths / totalBirds) * 100 : 0;\nconst fishMortalityRate = totalFish > 0 ? (fishDeaths / totalFish) * 100 : 0;\n\nconst THRESHOLD = 2;\n\nlet alertStatus = \"Normal\";\nif (birdMortalityRate >= THRESHOLD && fishMortalityRate >= THRESHOLD) {\n  alertStatus = \"Both Alert\";\n} else if (birdMortalityRate >= THRESHOLD) {\n  alertStatus = \"Bird Alert\";\n} else if (fishMortalityRate >= THRESHOLD) {\n  alertStatus = \"Fish Alert\";\n}\n\nreturn {\n  date,\n  eggsCollected,\n  totalBirds,\n  birdDeaths,\n  birdMortalityRate: Math.round(birdMortalityRate * 100) / 100,\n  pondId,\n  avgFishWeight,\n  totalFish,\n  fishDeaths,\n  fishMortalityRate: Math.round(fishMortalityRate * 100) / 100,\n  alertStatus\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
